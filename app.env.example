# Copy to app.env (gitignored) and fill in real values for your environment.
ENVIRONMENT=development
DB_SOURCE=postgresql://root:secret@localhost:5432/glutenfree?sslmode=disable
MIGRATION_URL=file://db/migration
HTTP_SERVER_ADDRESS=0.0.0.0:8080
# Must be >= 32 chars (HS256 symmetric key). Generate one for production.
TOKEN_SYMMETRIC_KEY=change-me-to-a-32+char-random-secret
ACCESS_TOKEN_DURATION=15m
REFRESH_TOKEN_DURATION=720h
ALLOWED_ORIGINS=*

# StoreKit 2 / App Store subscriptions. Leave APPLE_ROOT_CA_PATH blank to
# disable /subscription/verify + /webhooks/apple. Download Apple Root CA - G3
# (PEM or DER) from https://www.apple.com/certificateauthority/
APPLE_ROOT_CA_PATH=

# APPLE_BUNDLE_ID is the iOS app's bundle identifier. It is used both to pin
# StoreKit transactions AND as the audience for Sign in with Apple identity
# tokens (POST /auth/apple). Leave blank to disable /auth/apple.
APPLE_BUNDLE_ID=com.glutenfree.gf

# In containers there is no app.env file — set the variables above directly in
# the environment. DB_SOURCE, TOKEN_SYMMETRIC_KEY and HTTP_SERVER_ADDRESS are
# the minimum required.
